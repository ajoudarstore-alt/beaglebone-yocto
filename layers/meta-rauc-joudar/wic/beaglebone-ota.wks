part /boot --source bootimg-partition --ondisk mmcblk0 --fstype=vfat --label bootA --active --align 4096 --size 100
part /boot --source bootimg-partition --ondisk mmcblk0 --fstype=vfat --label bootB  --align 4096 --size 100
part / --source rootfs --ondisk mmcblk0 --fstype=ext4 --label rootfsA --align 4096
part / --source rootfs --ondisk mmcblk0 --fstype=ext4 --label rootfsB --align 4096
